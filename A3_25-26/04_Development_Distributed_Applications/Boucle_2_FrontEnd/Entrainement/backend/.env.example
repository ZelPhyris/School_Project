# Copier ce fichier en .env puis adapter les valeurs
PORT=5000

# Connexion MongoDB.
# - WSL -> MongoDB Windows : utiliser 127.0.0.1 (forwarding WSL2) ou l'IP de l'hote Windows.
# - MongoDB local Linux    : mongodb://127.0.0.1:27017
# - MongoDB Atlas (cloud)  : mongodb+srv://<user>:<pass>@<cluster>/...
MONGODB_URI=mongodb://127.0.0.1:27017/crud_demo

# Origine autorisee pour le front-end React (CORS)
CLIENT_URL=http://localhost:5173
